<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Quan4CulinaryTourism.Mobile.Views.SettingsPage">
    <ScrollView>
        <VerticalStackLayout Padding="20,16" Spacing="16">
            <Border>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Ngon ngu noi dung" Style="{StaticResource SectionTitleLabel}" />
                    <Picker ItemsSource="{Binding Languages}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedLanguageOption}" />
                    <Button Text="Cap nhat ngon ngu" Command="{Binding ChangeLanguageCommand}" />
                </VerticalStackLayout>
            </Border>

            <Border>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Theme" Style="{StaticResource SectionTitleLabel}" />
                    <Picker ItemsSource="{Binding Themes}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedThemeOption}" />
                    <Button Text="Ap dung theme" Command="{Binding ChangeThemeCommand}" BackgroundColor="{StaticResource Secondary}" />
                </VerticalStackLayout>
            </Border>

            <Border>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Backend base URL" Style="{StaticResource SectionTitleLabel}" />
                    <Picker ItemsSource="{Binding ApiEndpoints}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedEndpointOption}" />
                    <Button Text="Dung preset" Command="{Binding ApplyEndpointPresetCommand}" BackgroundColor="{StaticResource Secondary}" />
                    <Entry Text="{Binding ApiBaseUrl}" Placeholder="http://192.168.1.50:5163" />
                    <Button Text="Luu backend URL" Command="{Binding SaveApiBaseUrlCommand}" />
                </VerticalStackLayout>
            </Border>

            <Border>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Auto Narration" Style="{StaticResource SectionTitleLabel}" />
                    <HorizontalStackLayout Spacing="12">
                        <Label Text="Bat tu dong phat/goi y audio khi vao geofence" VerticalOptions="Center" />
                        <Switch IsToggled="{Binding AutoNarrationEnabled}" />
                    </HorizontalStackLayout>
                    <Picker ItemsSource="{Binding NarrationRadiusOptions}"
                            SelectedItem="{Binding SelectedNarrationRadius}"
                            Title="Ban kinh mac dinh" />
                    <Button Text="Luu Auto Narration" Command="{Binding SaveNarrationSettingsCommand}" />
                    <Label Text="Tracking status" Style="{StaticResource SectionTitleLabel}" />
                    <Label Text="{Binding TrackingStatus}" />
                </VerticalStackLayout>
            </Border>

            <Border>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Offline pack" Style="{StaticResource SectionTitleLabel}" />
                    <Label Text="{Binding OfflinePackStatus}" />
                    <Label Text="{Binding OfflinePackSummary}" TextColor="{AppThemeBinding Light={StaticResource LightMutedText}, Dark={StaticResource DarkMutedText}}" />
                    <HorizontalStackLayout Spacing="12">
                        <Label Text="San sang offline" VerticalOptions="Center" />
                        <Switch IsToggled="{Binding OfflinePackReady}" IsEnabled="False" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="12">
                        <Label Text="Tai audio offline" VerticalOptions="Center" />
                        <Switch IsToggled="{Binding DownloadAudioForOffline}" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="12">
                        <Label Text="Tai map pack neu backend co file" VerticalOptions="Center" />
                        <Switch IsToggled="{Binding DownloadMapPackForOffline}" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="12">
                        <Button Text="Chuan bi offline" Command="{Binding PrepareOfflinePackCommand}" />
                        <Button Text="Refresh offline status" Command="{Binding RefreshOfflineStatusCommand}" BackgroundColor="{StaticResource Secondary}" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Backend status" Style="{StaticResource SectionTitleLabel}" />
                    <Label Text="{Binding BackendStatus}" />
                    <Label Text="App version" Style="{StaticResource SectionTitleLabel}" />
                    <Label Text="{Binding AppVersion}" />
                    <Button Text="Xoa cache offline" Command="{Binding ClearCacheCommand}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
