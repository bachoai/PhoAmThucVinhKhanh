<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Quan4CulinaryTourism.Mobile.Views.MapPage">
    <Grid RowDefinitions="Auto,*">
        <Border Margin="20,16,20,0">
            <VerticalStackLayout Spacing="10">
                <Label Text="{Binding MapStatus}" TextColor="{AppThemeBinding Light={StaticResource LightMutedText}, Dark={StaticResource DarkMutedText}}" />
                <HorizontalStackLayout Spacing="12">
                    <Button Text="Center" Command="{Binding CenterOnUserCommand}" />
                    <Button Text="Refresh" Command="{Binding RefreshCommand}" BackgroundColor="{StaticResource Secondary}" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>
        <VerticalStackLayout Grid.Row="1" Padding="20,16" Spacing="12">
            <ContentView x:Name="MapHost" HeightRequest="320" />
            <CollectionView ItemsSource="{Binding Pois}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding Name}" Style="{StaticResource SectionTitleLabel}" />
                                <Label Text="{Binding DisplayAddress}" />
                                <HorizontalStackLayout Spacing="10">
                                    <Button Text="Xem chi tiết"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenDetailCommand}"
                                            CommandParameter="{Binding Id}" />
                                    <Button Text="Mở Google Maps"
                                            BackgroundColor="{StaticResource Secondary}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenExternalMapCommand}"
                                            CommandParameter="{Binding Id}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
