<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Quan4CulinaryTourism.Mobile.Views.QrEntryPage">
    <ScrollView>
        <VerticalStackLayout Padding="20,16" Spacing="18">
            <Border>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Demo QR / Nhập mã POI"
                           Style="{StaticResource PageTitleLabel}" />
                    <Label Text="Nếu chưa thêm scanner thật, dùng màn này để demo flow mở chi tiết từ QR hoặc POI id."
                           TextColor="{AppThemeBinding Light={StaticResource LightMutedText}, Dark={StaticResource DarkMutedText}}" />
                    <Entry Text="{Binding PoiCode}"
                           Placeholder="Ví dụ: 6657f02d9b... hoặc quan4tourism://poi/6657f02d9b..." />
                    <Button Text="Mở chi tiết POI" Command="{Binding OpenPoiCommand}" />
                    <Label Text="{Binding ErrorMessage}"
                           IsVisible="{Binding HasError}"
                           TextColor="{StaticResource Danger}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
