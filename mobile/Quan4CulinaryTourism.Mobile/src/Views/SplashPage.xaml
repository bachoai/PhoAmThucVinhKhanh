<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Quan4CulinaryTourism.Mobile.Views.SplashPage"
             Shell.NavBarIsVisible="False">
    <Grid Background="{StaticResource Primary}">
        <VerticalStackLayout Padding="24" Spacing="20" VerticalOptions="Center">
            <Label Text="Quan4 Culinary Tourism"
                   FontSize="34"
                   FontFamily="OpenSansSemibold"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />
            <Label Text="Khám phá ẩm thực Quận 4"
                   TextColor="White"
                   FontSize="18"
                   HorizontalTextAlignment="Center" />
            <ActivityIndicator IsRunning="True" Color="White" />

            <Border IsVisible="{Binding ShowLanguageSelector}"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Chọn ngôn ngữ" Style="{StaticResource SectionTitleLabel}" />
                    <Picker ItemsSource="{Binding Languages}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedLanguageOption}" />
                    <Button Text="Tiếp tục" Command="{Binding ContinueCommand}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
