<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Quan4CulinaryTourism.Mobile.Components"
             x:Class="Quan4CulinaryTourism.Mobile.Components.CategoryChipView"
             x:Name="Self">
    <Border BackgroundColor="{StaticResource Secondary}"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 16">
        <Label Padding="12,6"
               Text="{Binding Source={x:Reference Self}, Path=Text}"
               TextColor="White" />
    </Border>
</ContentView>
