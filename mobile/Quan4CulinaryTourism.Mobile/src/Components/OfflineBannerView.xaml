<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Quan4CulinaryTourism.Mobile.Components.OfflineBannerView"
             x:Name="Self">
    <Border BackgroundColor="{StaticResource WarningSoft}"
            Stroke="{StaticResource Warning}"
            StrokeShape="RoundRectangle 16"
            Padding="12"
            IsVisible="{Binding Source={x:Reference Self}, Path=IsOffline}">
        <Label Text="Đang hiển thị dữ liệu cache offline."
               TextColor="{StaticResource WarningText}" />
    </Border>
</ContentView>
