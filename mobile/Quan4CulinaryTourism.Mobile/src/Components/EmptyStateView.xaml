<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Quan4CulinaryTourism.Mobile.Components"
             x:Class="Quan4CulinaryTourism.Mobile.Components.EmptyStateView"
             x:Name="Self">
    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
        <Label Text="🍜" FontSize="36" HorizontalTextAlignment="Center" />
        <Label Text="{Binding Source={x:Reference Self}, Path=TitleText}"
               Style="{StaticResource SectionTitleLabel}"
               HorizontalTextAlignment="Center" />
        <Label Text="{Binding Source={x:Reference Self}, Path=DescriptionText}"
               HorizontalTextAlignment="Center"
               TextColor="{AppThemeBinding Light={StaticResource LightMutedText}, Dark={StaticResource DarkMutedText}}" />
    </VerticalStackLayout>
</ContentView>
