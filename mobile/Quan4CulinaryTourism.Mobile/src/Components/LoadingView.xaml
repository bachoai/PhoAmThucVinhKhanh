<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Quan4CulinaryTourism.Mobile.Components"
             x:Class="Quan4CulinaryTourism.Mobile.Components.LoadingView"
             x:Name="Self">
    <VerticalStackLayout Spacing="12" HorizontalOptions="Center" VerticalOptions="Center">
        <ActivityIndicator IsRunning="True" />
        <Label Text="{Binding Source={x:Reference Self}, Path=Message}" />
    </VerticalStackLayout>
</ContentView>
