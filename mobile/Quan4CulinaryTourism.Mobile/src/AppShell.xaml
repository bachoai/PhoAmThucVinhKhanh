<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Quan4CulinaryTourism.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Quan4CulinaryTourism.Mobile.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="Quan4 Culinary Tourism">
    <ShellContent
        Title="Splash"
        Route="splash"
        Shell.TabBarIsVisible="False"
        ContentTemplate="{DataTemplate views:SplashPage}" />

    <TabBar Route="root">
        <ShellContent
            Title="Trang chủ"
            Route="home"
            ContentTemplate="{DataTemplate views:HomePage}" />
        <ShellContent
            Title="Địa điểm"
            Route="poi-list"
            ContentTemplate="{DataTemplate views:PoiListPage}" />
        <ShellContent
            Title="Nearby"
            Route="nearby"
            ContentTemplate="{DataTemplate views:NearbyPage}" />
        <ShellContent
            Title="Bản đồ"
            Route="map"
            ContentTemplate="{DataTemplate views:MapPage}" />
        <ShellContent
            Title="Cài đặt"
            Route="settings"
            ContentTemplate="{DataTemplate views:SettingsPage}" />
    </TabBar>
</Shell>
